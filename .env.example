# ============================================================
# AI Mülakat Platformu — Tüm Servisler İçin Env Şablonu
# ============================================================
# Kullanım: Bu dosyayı docker/.env olarak kopyala
#   cp .env.example docker/.env
# Detaylı ayarlar için:
#   docker/.env.example         → Docker Compose değişkenleri
#   src/frontend/.env.example   → Frontend (VITE_*)
#   services/speech-service/    → Speech servisi profil dosyaları
# ============================================================

# ── Veritabanı (PostgreSQL) ─────────────────────────────────
POSTGRES_USER=coach
POSTGRES_PASSWORD=coachpass
POSTGRES_DB=interviewcoach
POSTGRES_PORT=5432

# ── Servis Portları ─────────────────────────────────────────
API_PORT=8080           # .NET backend
FRONTEND_PORT=5173      # React/Vite
SPEECH_PORT=8000        # faster-whisper STT
OLLAMA_PORT=11434       # Ollama LLM

# ── Frontend ─────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080/api
VITE_SPEECH_URL=http://localhost:8000
VITE_STITCH_API_KEY=    # Google Stitch AI (opsiyonel)
FRONTEND_ORIGIN=http://localhost:5173

# ── LLM (Ollama) ─────────────────────────────────────────────
LLM_MODEL=qwen2.5:7b-instruct   # ollama pull ile indir
LLM_TIMEOUT_SECONDS=60

# ── Speech Service (faster-whisper) ─────────────────────────
SPEECH_MODEL=large-v3-turbo     # İlk çalıştırmada ~1.5 GB indirilir
SPEECH_DEVICE=cuda              # GPU yoksa: cpu
SPEECH_COMPUTE_TYPE=int8_float16  # CPU için: int8
SPEECH_CPU_THREADS=4
SPEECH_NUM_WORKERS=1
SPEECH_BEAM_SIZE=1
SPEECH_BEST_OF=1
SPEECH_NO_SPEECH_THRESHOLD=0.4
STRICT_QUALITY_MODE=false
