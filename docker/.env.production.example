# -----------------------------
# Core host/domain
# -----------------------------
PUBLIC_HTTP_PORT=80
PUBLIC_HTTPS_PORT=443
APP_DOMAIN=app.example.com
FRONTEND_PUBLIC_BASE_URL=https://app.example.com
API_PUBLIC_BASE_URL=https://app.example.com/api

# -----------------------------
# PostgreSQL (required)
# -----------------------------
POSTGRES_USER=coach
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=interviewcoach

# -----------------------------
# Auth / JWT (required)
# -----------------------------
AUTH_JWT_ISSUER=InterviewCoach
AUTH_JWT_AUDIENCE=InterviewCoachClient
AUTH_JWT_KEY=change-this-to-a-long-random-secret-at-least-32-chars
AUTH_ACCESS_TOKEN_MINUTES=120

# -----------------------------
# CORS / frontend origin (required)
# -----------------------------
CORS_ALLOWED_ORIGIN=https://app.example.com

# -----------------------------
# Frontend build-time URLs (required for reverse proxy setup)
# -----------------------------
VITE_API_URL=/api
VITE_SPEECH_URL=/speech

# -----------------------------
# Optional LLM/Speech services
# -----------------------------
LLM_BASE_URL=http://ollama:11434
LLM_MODEL=qwen2.5:7b-instruct
LLM_TIMEOUT_SECONDS=60
SPEECH_MODEL=small

# -----------------------------
# Optional operational toggles
# -----------------------------
TELEMETRY_ENABLED=false
TELEMETRY_OTLP_ENDPOINT=

RETENTION_ENABLED=true
RETENTION_DELETE_AFTER_DAYS=30
RETENTION_KEEP_SUMMARIES_ONLY_AFTER_DAYS=7
RETENTION_RUN_HOUR_UTC=3

PRIVACY_REDACT_TRANSCRIPTS=true
PRIVACY_REDACT_ON_INGEST=true
PRIVACY_STORE_ORIGINAL_TRANSCRIPTS=false
