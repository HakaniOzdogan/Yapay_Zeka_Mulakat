@page "/interview"
@using InterviewAI.Frontend.Services
@inject NavigationManager Navigation
@inject ApiService ApiService

<PageTitle>Start Interview</PageTitle>

<div class="container mt-5">
    <h1>Start Interview</h1>
    
    <div class="row">
        @foreach (var type in new[] { "Technical", "Behavioral", "HR" })
        {
            <div class="col-md-4">
                <button class="btn btn-outline-primary btn-block" @onclick="@((MouseEventArgs e) => SelectType(type))">
                    @type
                </button>
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(selectedType))
    {
        <div class="mt-3">
            <label>Number of Questions:</label>
            <input type="number" @bind="totalQuestions" min="1" max="20" class="form-control" />
            <button class="mt-2 btn btn-success" @onclick="StartInterview">Start</button>
        </div>
    }
</div>

@code {
    private string selectedType = "";
    private int totalQuestions = 5;

    private void SelectType(string type)
    {
        selectedType = type;
    }

    private async Task StartInterview()
    {
        if (string.IsNullOrEmpty(selectedType)) return;

        try
        {
            var interview = new InterviewDto
            {
                JobPosition = selectedType,
                StartedAt = DateTime.Now,
                Status = "In Progress",
                TotalQuestions = totalQuestions
            };

            var result = await ApiService.CreateInterviewAsync(interview);
            Navigation.NavigateTo($"/interview-session/{result.Id}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }
}
