{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore": "Debug"
    }
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=interviewcoach;Username=coach;Password=coachpass"
  },
  "ScoringProfiles": {
    "DefaultProfile": "general",
    "Profiles": {
      "general": {
        "weights": {
          "eyeContact": 0.25,
          "posture": 0.15,
          "fidget": 0.10,
          "speakingRate": 0.25,
          "fillerWords": 0.25
        },
        "thresholds": {
          "speakingRateIdealMinWpm": 120,
          "speakingRateIdealMaxWpm": 170,
          "fillerPerMinMax": 6,
          "eyeContactMin": 0.55,
          "headJitterMax": 0.35,
          "fidgetMax": 0.40,
          "postureMin": 0.60
        }
      },
      "technical": {
        "weights": {
          "eyeContact": 0.15,
          "posture": 0.10,
          "fidget": 0.10,
          "speakingRate": 0.30,
          "fillerWords": 0.35
        },
        "thresholds": {
          "speakingRateIdealMinWpm": 130,
          "speakingRateIdealMaxWpm": 180,
          "fillerPerMinMax": 4,
          "eyeContactMin": 0.50,
          "headJitterMax": 0.40,
          "fidgetMax": 0.45,
          "postureMin": 0.55
        }
      },
      "hr": {
        "weights": {
          "eyeContact": 0.30,
          "posture": 0.20,
          "fidget": 0.15,
          "speakingRate": 0.15,
          "fillerWords": 0.20
        },
        "thresholds": {
          "speakingRateIdealMinWpm": 110,
          "speakingRateIdealMaxWpm": 160,
          "fillerPerMinMax": 5,
          "eyeContactMin": 0.60,
          "headJitterMax": 0.30,
          "fidgetMax": 0.35,
          "postureMin": 0.65
        }
      }
    }
  },
  "Llm": {
    "BaseUrl": "http://localhost:11434",
    "Model": "qwen2.5:7b-instruct",
    "FallbackModels": [
      "qwen2.5:3b-instruct"
    ],
    "TimeoutSeconds": 60,
    "Temperature": 0.2,
    "PromptVersionCoach": "coach_v1",
    "Retry": {
      "MaxAttemptsPrimary": 2,
      "RetryOnInvalidJson": true,
      "RetryOnTimeout": true,
      "RetryOnHttp5xx": true,
      "BackoffMs": [ 500, 1000 ]
    },
    "Fallback": {
      "Enabled": true,
      "TryFallbackModelsOnFailure": true,
      "UseCachedSameInputHashIfAllFail": true,
      "UseCachedAnyPreviousForSessionIfSameInputMissing": false,
      "CacheFallbackMaxAgeHours": 168
    }
  },
  "LlmGuardrails": {
    "Enabled": true,
    "MinQualityScore": 50,
    "MaxDuplicateFeedbackRatio": 0.4,
    "EnableProfanityFilter": true,
    "EnableMedicalOverreachFilter": true,
    "EnablePiiRedaction": true,
    "StrictGrounding": true
  },
  "LlmOptimization": {
    "Enabled": true,
    "DefaultTier": "medium",
    "MaxPromptChars": {
      "Small": 6000,
      "Medium": 12000,
      "Full": 22000
    },
    "MaxTranscriptSliceChars": {
      "Small": 1200,
      "Medium": 2400,
      "Full": 4000
    },
    "MaxWorstWindows": {
      "Small": 3,
      "Medium": 5,
      "Full": 8
    },
    "MaxPatterns": {
      "Small": 3,
      "Medium": 6,
      "Full": 10
    },
    "ModelRouting": {
      "Enabled": true,
      "ComplexityThresholds": {
        "Low": 30,
        "High": 70
      },
      "Routes": {
        "Low": "qwen2.5:3b-instruct",
        "Medium": "qwen2.5:7b-instruct",
        "High": "qwen2.5:7b-instruct"
      }
    },
    "ForceFullForDebug": false,
    "IncludeTranscriptSlicesInSmallTier": true
  },
  "BatchCoaching": {
    "Enabled": true,
    "PollIntervalSeconds": 5,
    "MaxParallelism": 2,
    "MaxSessionsPerJob": 500,
    "ResetStaleRunningJobsOnStartup": true,
    "StaleRunningJobMinutes": 30,
    "ItemRetryCount": 0
  },
  "Retention": {
    "Enabled": true,
    "DeleteAfterDays": 30,
    "KeepSummariesOnlyAfterDays": 7,
    "RunHourUtc": 3
  },
  "Privacy": {
    "RedactTranscripts": true,
    "RedactOnIngest": true,
    "StoreOriginalTranscripts": false
  },
  "Telemetry": {
    "Enabled": true,
    "OtlpEndpoint": "",
    "ServiceName": "InterviewCoach",
    "ServiceVersion": ""
  },
  "Cors": {
    "AllowedOrigin": ""
  },
  "Auth": {
    "JwtIssuer": "InterviewCoach",
    "JwtAudience": "InterviewCoach.Client",
    "JwtKey": "dev-only-change-this-key-to-a-long-random-secret",
    "AccessTokenMinutes": 120,
    "SeedAdminEmail": "",
    "SeedAdminPassword": ""
  }
}
