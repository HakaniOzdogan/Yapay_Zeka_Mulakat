# Speech service production hardening defaults
# New connections are rejected when active sessions hit MAX_CONCURRENT_SESSIONS.
MAX_CONCURRENT_SESSIONS=10
# Backpressure policy: briefly wait for queue capacity before returning an overload signal.
MAX_QUEUE_MESSAGES_PER_CONN=50
# Max accumulated utterance buffer before forced flush/reset.
MAX_AUDIO_BUFFER_MS_PER_CONN=15000
# Close idle websocket if no client message arrives within timeout.
CLIENT_IDLE_TIMEOUT_SEC=60
# How long inbound audio waits for queue capacity before server asks client to retry.
BACKPRESSURE_QUEUE_WAIT_MS=1000
# Timeout per utterance transcription call.
TRANSCRIBE_TIMEOUT_SEC=20

# VAD/partial tuning
VAD_SILENCE_MS=900
VAD_ENERGY_THRESHOLD=0.008
VAD_MIN_SPEECH_MS=600
VAD_MIN_SPEECH_RATIO=0.35
VAD_DYNAMIC_THRESHOLD_MULTIPLIER=2.4
STREAM_DECODE_INTERVAL_MS=900
STREAM_DECODE_OVERLAP_MS=800
STREAM_MAX_ACTIVE_WINDOW_MS=6000
STREAM_COMMIT_AGREEMENT_PASSES=1
STRICT_QUALITY_MODE=false
SPEECH_VIBEVOICE_TOKENIZER_CHUNK_SIZE=960000
SPEECH_VAD_BACKEND=silero
SPEECH_VAD_FALLBACK=energy

# Model selection
# Choices: tiny, base, small, medium, large-v2, large-v3, large-v3-turbo
# Default startup now targets the Hugging Face VibeVoice ASR model.
MODEL=microsoft/VibeVoice-ASR-HF
SPEECH_LATENCY_PROFILE=quality
SPEECH_BEAM_SIZE=2
SPEECH_BEST_OF=2
SPEECH_NO_SPEECH_THRESHOLD=0.65

# Compute type for GPU acceleration
# int8_float16 → ~2x less VRAM than float16, minimal quality loss (recommended for 4GB VRAM)
# float16       → full precision, needs more VRAM
# int8          → CPU-optimized
SPEECH_COMPUTE_TYPE=int8_float16
SPEECH_DEVICE=cuda

# CTranslate2 thread count for CPU-side ops (encoder pre/post-processing).
# Recommended: physical_cores / 2. For RTX 3050 Ti system: 8.
SPEECH_CPU_THREADS=8

# Concurrent transcription workers inside CTranslate2.
# Use 1 per GPU. Increase only for multi-GPU setups.
SPEECH_NUM_WORKERS=1
